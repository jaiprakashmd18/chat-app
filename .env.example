# Database
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/studentexpress?retryWrites=true&w=majority"

# NextAuth
NEXTAUTH_URL="https://your-domain.vercel.app"
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"

# Vercel KV (Redis)
KV_URL="redis://default:password@host:port"
KV_REST_API_URL="https://your-kv.kv.vercel-storage.com"
KV_REST_API_TOKEN="your-kv-token"
KV_REST_API_READ_ONLY_TOKEN="your-kv-read-only-token"

# Email - Resend
RESEND_API_KEY="re_xxxxxxxx"
EMAIL_FROM="noreply@studentexpress.ge"

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-key"

# App
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"
NEXT_PUBLIC_APP_NAME="StudentExpress Georgia"

# OTP Settings
OTP_EXPIRY_MINUTES="10"

# Admin
ADMIN_EMAIL="admin@studentexpress.ge"
