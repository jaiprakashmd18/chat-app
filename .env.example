# ─── Copy this file to .env for local dev ────────────────────────────────────
# On Vercel add these under Project → Settings → Environment Variables

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Create a free cluster at https://mongodb.com/atlas
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/mechat?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# ── Cloudinary ────────────────────────────────────────────────────────────────
# https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
# Gmail: use an App Password (not your normal password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=MeCHAT <noreply@mechat.app>

# ── CORS / Client URL ─────────────────────────────────────────────────────────
# The URL Vercel assigns to your project (found in Project → Domains)
CLIENT_URL=https://your-project.vercel.app

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# ── AI Assistant (optional) ───────────────────────────────────────────────────
# Leave blank to use the built-in fallback responses
OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND env vars (prefix must be VITE_)
# Set these in Vercel too — they are embedded at build time
# ─────────────────────────────────────────────────────────────────────────────

# Leave blank when backend is deployed on the same Vercel project (uses /api)
VITE_API_URL=

# Optional: URL of a separate real-time backend (Railway / Render / Fly.io)
# Set this if you want full WebSocket support instead of long-polling.
# If blank, Socket.IO uses polling via the same Vercel domain.
VITE_SOCKET_URL=
